---
import { siteConfig } from "@/data/config";
import { ModeToggle } from "@/components/ModeToggle";
import "../styles/globals.css";

interface Props {
	title?: string;
	description?: string;
	activePage?: string;
}

const {
	title = siteConfig.title,
	description = siteConfig.description,
	activePage = "",
} = Astro.props;

const fullTitle = title === siteConfig.title ? title : `${title} — ${siteConfig.title}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<title>{fullTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		{import.meta.env.PUBLIC_POSTHOG_KEY && import.meta.env.PUBLIC_POSTHOG_HOST && (
			<script is:inline>
				!function(t,e){var o,n,a,r;e._posthog=e._posthog||{},(a=e._posthog.q=e._posthog.q||[]).push([Date.now()].concat([].slice.call(arguments,0))),r=e._posthog,r.__SV=1;var i=t.createElement("script");i.type="text/javascript",i.async=!0,i.crossOrigin="anonymous",i.src="{import.meta.env.PUBLIC_POSTHOG_HOST}/array.js",(n=t.getElementsByTagName("script")[0]).parentNode.insertBefore(i,n);for(var s=function(e){return function(){a.push([Date.now()].concat([].slice.call(arguments,0),[e]))}},c=["identify","capture","set","setPersonProperties","optIn","optOut","reset","getFeatureFlag","getFeatureFlagPayload","isFeatureEnabled","reloadFeatures"],u=0;u<c.length;u++)r[c[u]]=s(c[u])}(document,window);posthog.init('{import.meta.env.PUBLIC_POSTHOG_KEY}',{api_host:'{import.meta.env.PUBLIC_POSTHOG_HOST}'})
			</script>
		)}
	</head>
	<body class="min-h-screen bg-background text-foreground">
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
					return localStorage.getItem("theme");
				}
				return window.matchMedia("(prefers-color-scheme: dark)").matches
					? "dark"
					: "light";
			};
			const isDark = getThemePreference() === "dark";
			document.documentElement.classList[isDark ? "add" : "remove"]("dark");
			if (typeof localStorage !== "undefined") {
				const observer = new MutationObserver(() => {
					const isDark = document.documentElement.classList.contains("dark");
					localStorage.setItem("theme", isDark ? "dark" : "light");
				});
				observer.observe(document.documentElement, {
					attributes: true,
					attributeFilter: ["class"],
				});
			}
		</script>

		<nav class="mx-auto flex max-w-3xl items-baseline justify-between border-b border-border px-6 pb-6 pt-12">
			<div class="font-[family-name:var(--font-display)] text-lg">
				<a href="/" class="text-foreground hover:text-foreground/80">
					Eeshan <em>Srivastava</em>
				</a>
			</div>
			<div class="flex items-center gap-6">
				<ul class="flex gap-6">
					{siteConfig.nav.map((item) => (
						<li>
							<a
								href={item.href}
								class:list={[
									"text-xs font-medium uppercase tracking-wider text-muted-foreground transition-colors hover:text-foreground",
									activePage === item.href && "text-foreground",
								]}
							>
								{item.label}
							</a>
						</li>
					))}
				</ul>
				<ModeToggle client:load />
			</div>
		</nav>

		<main class="mx-auto max-w-3xl px-6 pt-8 pb-20">
			<slot />
		</main>

		<footer class="mx-auto flex max-w-3xl items-center justify-between border-t border-border px-6 py-6 text-xs text-muted-foreground">
			<span>© {new Date().getFullYear()} Eeshan Srivastava</span>
			<span>Open source · Non-commercial</span>
		</footer>
	</body>
</html>