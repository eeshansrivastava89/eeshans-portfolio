---
import { siteConfig } from "@/data/config";
import { ModeToggle } from "@/components/ModeToggle";
import "../styles/globals.css";

interface Props {
	title?: string;
	description?: string;
	activePage?: string;
}

const {
	title = siteConfig.title,
	description = siteConfig.description,
	activePage = "",
} = Astro.props;

const fullTitle = title === siteConfig.title ? title : `${title} — ${siteConfig.title}`;

const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<title>{fullTitle}</title>
		<meta name="generator" content={Astro.generator} />
		{posthogKey && posthogHost && (
			<script is:inline define:vars={{ posthogKey, posthogHost }}>
				!function(t,e){var o,n,a,r;e._posthog=e._posthog||{},(a=e._posthog.q=e._posthog.q||[]).push([Date.now()].concat([].slice.call(arguments,0))),r=e._posthog,r.__SV=1;var i=t.createElement("script");i.type="text/javascript",i.async=!0,i.crossOrigin="anonymous",i.src=posthogHost+"/array.js",(n=t.getElementsByTagName("script")[0]).parentNode.insertBefore(i,n);for(var s=function(e){return function(){a.push([Date.now()].concat([].slice.call(arguments,0),[e]))}},c=["identify","capture","set","setPersonProperties","optIn","optOut","reset","getFeatureFlag","getFeatureFlagPayload","isFeatureEnabled","reloadFeatures"],u=0;u<c.length;u++)r[c[u]]=s(c[u])}(document,window);posthog.init(posthogKey,{api_host:posthogHost})
			</script>
		)}
	</head>
	<body class="min-h-screen bg-background text-foreground">
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
					return localStorage.getItem("theme");
				}
				return window.matchMedia("(prefers-color-scheme: dark)").matches
					? "dark"
					: "light";
			};
			const isDark = getThemePreference() === "dark";
			document.documentElement.classList[isDark ? "add" : "remove"]("dark");
			if (typeof localStorage !== "undefined") {
				const observer = new MutationObserver(() => {
					const isDark = document.documentElement.classList.contains("dark");
					localStorage.setItem("theme", isDark ? "dark" : "light");
				});
				observer.observe(document.documentElement, {
					attributes: true,
					attributeFilter: ["class"],
				});
			}
		</script>

		<nav class="mx-auto flex max-w-4xl items-baseline justify-between border-b border-border px-6 pb-6 pt-12">
			<div class="font-[family-name:var(--font-display)] text-lg">
				<a href="/" class="text-foreground hover:text-foreground/80">
					Eeshan <em>Srivastava</em>
				</a>
			</div>
			<div class="flex items-center gap-6">
				<ul class="flex gap-6">
					{siteConfig.nav.map((item) => (
						<li>
							<a
								href={item.href}
								class:list={[
									"text-xs font-medium uppercase tracking-wider text-muted-foreground transition-colors hover:text-foreground",
									activePage === item.href && "text-foreground",
								]}
							>
								{item.label}
							</a>
						</li>
					))}
				</ul>
				<ModeToggle client:load />
			</div>
		</nav>

		<main class="mx-auto max-w-4xl px-6 pt-10 pb-24">
			<slot />
		</main>

		<footer class="mx-auto flex max-w-4xl items-center justify-between border-t border-border px-6 py-8 text-xs text-muted-foreground">
			<span>© {new Date().getFullYear()} Eeshan Srivastava</span>
			<span>Open source · Non-commercial</span>
		</footer>

		<script is:inline>
			// Demo video: click-to-pause with styled overlay, auto-pause when scrolled away
			document.addEventListener('click', (e) => {
				const wrap = (e.target).closest('.demo-video');
				if (!wrap) return;
				const video = wrap.querySelector('video');
				const overlay = wrap.querySelector('.demo-video-overlay');
				if (!video) return;
				if (video.paused) {
					video.play();
					overlay.style.opacity = '0';
					wrap.classList.remove('paused');
				} else {
					video.pause();
					overlay.style.opacity = '1';
					wrap.classList.add('paused');
				}
			});

			const io = new IntersectionObserver((entries) => {
				for (const entry of entries) {
					const video = entry.target.querySelector('video');
					const overlay = entry.target.querySelector('.demo-video-overlay');
					if (!video) continue;
					if (entry.isIntersecting) {
						if (!entry.target.classList.contains('paused')) video.play();
					} else {
						video.pause();
					}
				}
			}, { threshold: 0.25 });

			document.querySelectorAll('.demo-video').forEach((el) => io.observe(el));
		</script>
	</body>
</html>