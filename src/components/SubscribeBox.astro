---
import { Button } from "@/components/ui/button";
---

<div class="flex flex-wrap items-center justify-between gap-4 rounded-lg border border-border bg-paper-2 p-6 dark:bg-muted">
	<div>
		<div class="font-[family-name:var(--font-display)] text-xl">Asymptotic</div>
		<div class="text-sm text-muted-foreground">Essays on AI, data science, and what holds up after the hype.</div>
	</div>
	<Button asChild class="bg-accent hover:bg-accent-2 text-white">
		<a href="https://theasymptotic.substack.com/subscribe" target="_blank" rel="noopener noreferrer">
			Subscribe ↗
		</a>
	</Button>
</div>