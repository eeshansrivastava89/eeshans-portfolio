---
import { siteConfig } from "@/data/config";
import { brandIcons } from "@/data/icons";

const { kicker, tagline, href } = siteConfig.subscribe;
const substackIcon = brandIcons.substack;
---

<div class="sub-box">
	<div class="sub-copy">
		<span class="sub-kicker">{kicker}</span>
		<span class="sub-tagline">{tagline}</span>
	</div>
	<a href={href} target="_blank" rel="noopener noreferrer" class="sub-button">
		<svg viewBox={substackIcon.viewBox || "0 0 24 24"} fill="currentColor" aria-hidden="true" width="14" height="14"><path d={substackIcon.path} /></svg>
		Subscribe
	</a>
</div>

<style>
	.sub-box {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 18px 20px;
		border-radius: 16px;
		border: 1px solid color-mix(in oklab, var(--color-substack, #ff6719) 38%, var(--color-border));
		background: color-mix(in oklab, var(--color-substack, #ff6719) 8%, var(--color-background));
	}

	.sub-copy {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.sub-kicker {
		font-size: 0.85rem;
		font-weight: 800;
		letter-spacing: 0.01em;
		white-space: nowrap;
		color: var(--color-substack, #ff6719);
	}

	.sub-tagline {
		font-size: 1.05rem;
		color: var(--color-foreground);
	}

	.sub-button {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		flex-shrink: 0;
		padding: 8px 13px;
		border-radius: 999px;
		background: var(--color-substack, #ff6719);
		color: #fff;
		font-size: 0.85rem;
		font-weight: 800;
		text-decoration: none;
	}

	.sub-button:hover {
		background: color-mix(in oklab, var(--color-substack, #ff6719) 85%, #000);
		color: #fff;
		text-decoration: none;
	}

	@media (max-width: 520px) {
		.sub-box {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>