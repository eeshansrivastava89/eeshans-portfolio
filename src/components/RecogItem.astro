---
interface Props {
	icon: string;
	text: string;
	detail?: string;
	link?: string;
	year?: string;
}

const { icon, text, detail, link, year } = Astro.props;
---

<div class="flex items-baseline gap-2.5 py-2 border-b border-border last:border-b-0 text-sm">
	<span class="text-base shrink-0">{icon}</span>
	<div class="flex-1">
		{link ? (
			<a href={link} class="text-foreground hover:text-link-2 transition-colors" target="_blank" rel="noopener noreferrer">
				{text}
			</a>
		) : (
			<span class="text-foreground">{text}</span>
		)}
		{detail && <span class="text-xs text-muted-foreground"> — {detail}</span>}
	</div>
	{year && <span class="font-[family-name:var(--font-mono)] text-[0.7rem] text-muted-foreground whitespace-nowrap">{year}</span>}
</div>