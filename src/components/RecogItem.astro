---
import Icon from "./Icon.astro";

interface Props {
	icon: string;
	text: string;
	detail?: string;
	link?: string;
}

const { icon, text, detail, link } = Astro.props;
---

<div class="flex items-baseline gap-2.5 py-1.5 text-[0.88rem] text-foreground/80">
	<span class="shrink-0 text-accent"><Icon name={icon} size={14} /></span>
	<div class="flex-1 min-w-0">
		{link ? (
			<a href={link} class="text-foreground hover:text-link-2 transition-colors underline decoration-dotted underline-offset-4" target="_blank" rel="noopener noreferrer">
				{text}
			</a>
		) : (
			<span class="text-foreground">{text}</span>
		)}
		{detail && <span class="text-xs text-muted-foreground"> — {detail}</span>}
	</div>
</div>