---
interface Props {
	label?: string;
	href?: string;
}

const { label, href } = Astro.props;
---

{label && href ? (
	<h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-5 pb-2 border-b border-border flex justify-between items-baseline">
		<span>{label}</span>
		<a href={href} class="font-normal normal-case tracking-normal text-[0.78rem] text-muted-foreground hover:text-foreground transition-colors">
			See all →
		</a>
	</h2>
) : (
	<h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-5 pb-2 border-b border-border">
		{label}
	</h2>
)}