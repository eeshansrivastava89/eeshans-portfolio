---
interface Props {
	timespan: string;
	title: string;
	organization: string;
	detail?: string;
	logo?: string;
}

const { timespan, title, organization, detail, logo } = Astro.props;
---

<div class="flex items-start gap-5 py-5 border-b border-border last:border-b-0">
	{logo && (
		<img src={`/logos/${logo}`} alt="" class="w-11 h-11 rounded-lg border border-border bg-background shrink-0" />
	)}
	<div class="min-w-0">
		<div class="font-[family-name:var(--font-mono)] text-sm text-accent tracking-wide mb-0.5">{timespan}</div>
		<div class="font-medium text-foreground">{title} · {organization}</div>
		{detail && <div class="text-sm text-foreground/75 mt-0.5">{detail}</div>}
	</div>
</div>