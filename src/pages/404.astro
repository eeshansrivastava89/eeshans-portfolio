---
import BaseLayout from "@/layouts/Base.astro";
---

<BaseLayout title="404 Not Found">
	<div class="flex flex-col items-center justify-center py-24">
		<h1 class="font-[family-name:var(--font-display)] text-[5rem] text-accent leading-none">404</h1>
		<p class="text-xl text-foreground/80 mt-4">Page Not Found</p>
		<a href="/" class="mt-6 text-sm text-accent hover:text-accent-2 transition-colors">
			← Back home
		</a>
	</div>
</BaseLayout>