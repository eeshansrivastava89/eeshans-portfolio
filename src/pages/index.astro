---
import BaseLayout from "@/layouts/Base.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import ProjectCardContent from "@/components/ProjectCardContent.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import PostItem from "@/components/PostItem.astro";
import SubscribeBox from "@/components/SubscribeBox.astro";
import GitHubActivity from "@/components/GitHubActivity.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/data/config";
import { getLiveProjects, getVisiblePosts, formatDate } from "@/data/content";

const projects = await getLiveProjects();

const sortedProjects = projects;
const featuredProjects = sortedProjects.filter((p) => p.data.featured);
const topProjects = featuredProjects.length > 0 ? featuredProjects.slice(0, siteConfig.homepageProjectCount) : sortedProjects.slice(0, siteConfig.homepageProjectCount);

const sortedPosts = await getVisiblePosts();


---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
	<!-- Intro -->
	<section class="mb-20">
		<p class="text-lg text-foreground/80 leading-relaxed">{siteConfig.intro.tagline}</p>
		<SocialLinks class="mt-4" />
	</section>

	<!-- Projects -->
	<section class="mb-20">
		<SectionTitle label="Projects" href="/projects" />
		{topProjects.map((project) => (
			<ProjectCard>
				<ProjectCardContent
					title={project.data.title}
					status={project.data.status}
					hook={project.data.hook}
					liveUrl={project.data.liveUrl}
					repoUrl={project.data.repoUrl}
					tech={project.data.tech}
					videoWebm={project.data.videoWebm}
					videoMp4={project.data.videoMp4}
					videoPoster={project.data.videoPoster}
				/>
			</ProjectCard>
		))}
	</section>

	<!-- Writing -->
	<section class="mb-16">
		<SectionTitle label="Writing" href="/writing" />

		{sortedPosts.slice(0, siteConfig.homepagePostCount).map((post) => (
			<PostItem
				title={post.data.title}
				href={post.data.externalUrl}
				excerpt={post.data.description}
				date={formatDate(post.data.createdAt)}
				image={post.data.coverImage}
			/>
		))}
	</section>

	<!-- GitHub Activity -->
	<GitHubActivity />

	<!-- Subscribe -->
	<SubscribeBox />
</BaseLayout>