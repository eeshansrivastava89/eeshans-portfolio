---
import BaseLayout from "@/layouts/Base.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SeriesCard from "@/components/SeriesCard.astro";
import PostItem from "@/components/PostItem.astro";
import VideoShimmer from "@/components/VideoShimmer.astro";
import SubscribeBox from "@/components/SubscribeBox.astro";
import GitHubActivity from "@/components/GitHubActivity.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/data/config";

const projects = await getCollection("projects");
const posts = await getCollection("posts");

const sortedProjects = projects
	.filter((p) => p.data.status === "live")
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredProjects = sortedProjects.filter((p) => p.data.featured);
const topProjects = featuredProjects.length > 0 ? featuredProjects.slice(0, siteConfig.homepageProjectCount) : sortedProjects.slice(0, siteConfig.homepageProjectCount);

const sortedPosts = posts
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime());

const localAiSeriesPosts = sortedPosts.filter((p) => p.data.series === "local-ai");
const standalonePosts = sortedPosts.filter((p) => !p.data.series);

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
	<!-- Intro -->
	<section class="mb-16">
		<p class="text-base text-foreground/80 leading-relaxed">{siteConfig.intro.tagline}</p>
		<SocialLinks class="mt-4" />
	</section>

	<!-- Projects -->
	<section class="mb-16">
		<SectionTitle label="Projects" href="/projects" />
		{topProjects.map((project) => (
			<ProjectCard title={project.data.title} href={project.data.liveUrl || project.data.repoUrl} badge={project.data.featured ? { label: "Featured", variant: "featured" as const } : project.data.status === "live" ? { label: "Live", variant: "live" as const } : undefined}>
				<p class="text-base text-foreground/80 leading-relaxed mb-2">{project.data.hook}</p>
				<div class="flex flex-wrap items-center gap-2.5 font-[family-name:var(--font-mono)] text-xs text-muted-foreground">
					{project.data.liveUrl && <a href={project.data.liveUrl} class="hover:text-link transition-colors" target="_blank" rel="noopener noreferrer">Live</a>}
					{project.data.liveUrl && project.data.repoUrl && <span class="text-border">·</span>}
					{project.data.repoUrl && <a href={project.data.repoUrl} class="hover:text-link transition-colors" target="_blank" rel="noopener noreferrer">Source</a>}
					{project.data.analysisUrl && <><span class="text-border">·</span><a href={project.data.analysisUrl} class="hover:text-link transition-colors" target="_blank" rel="noopener noreferrer">Analysis</a></>}
					{project.data.relatedWriting && project.data.relatedWriting.length > 0 && <><span class="text-border">·</span><a href={`/writing`} class="hover:text-link transition-colors">Writeup →</a></>}
					{(project.data.liveUrl || project.data.repoUrl) && project.data.tech.length > 0 && <span class="text-border">·</span>}
					<span>{project.data.tech.join(" · ")}</span>
				</div>
				{project.data.stats && project.data.stats.length > 0 && (
					<div class="flex gap-4 mt-2">
						{project.data.stats.map((stat) => (
							<span class="font-[family-name:var(--font-mono)] text-xs">
								<span class="font-semibold text-accent">{stat.value}</span>
								{stat.label && <span class="text-muted-foreground"> {stat.label}</span>}
							</span>
						))}
					</div>
				)}
				{(project.data.videoWebm || project.data.videoMp4) ? (
					<video autoplay muted loop playsinline preload="metadata" class="mt-3 aspect-video rounded-lg border border-border" poster={project.data.videoPoster}>
						{project.data.videoWebm && <source src={project.data.videoWebm} type="video/webm" />}
						{project.data.videoMp4 && <source src={project.data.videoMp4} type="video/mp4" />}
					</video>
				) : (
					<VideoShimmer duration="45s" />
				)}
			</ProjectCard>
		))}
	</section>

	<!-- Writing -->
	<section class="mb-16">
		<SectionTitle label="Writing" href="/writing" />

		{localAiSeriesPosts.length > 0 && <SeriesCard seriesSlug="local-ai" />}

		{standalonePosts.slice(0, siteConfig.homepagePostCount).map((post) => (
			<PostItem
				title={post.data.title}
				href={post.data.externalUrl}
				excerpt={post.data.description}
				date={formatDate(post.data.createdAt)}
				projectLink={post.data.relatedProject ? { label: post.data.relatedProject, href: `/projects` } : undefined}
			/>
		))}
	</section>

	<!-- GitHub Activity -->
	<GitHubActivity />

	<!-- Subscribe -->
	<SubscribeBox />
</BaseLayout>