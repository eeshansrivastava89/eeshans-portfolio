---
import BaseLayout from "@/layouts/Base.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SeriesCard from "@/components/SeriesCard.astro";
import PostItem from "@/components/PostItem.astro";
import RecogItem from "@/components/RecogItem.astro";
import VideoShimmer from "@/components/VideoShimmer.astro";
import SubscribeBox from "@/components/SubscribeBox.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "@/data/config";

const projects = await getCollection("projects");
const posts = await getCollection("posts");
const impact = await getCollection("impact");
const aboutEntries = await getCollection("other");
const about = aboutEntries.find((e) => e.id === "about");
const aboutRendered = about ? await render(about) : null;

const sortedProjects = projects
	.filter((p) => p.data.status === "live")
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredProjects = sortedProjects.filter((p) => p.data.featured);
const topProjects = featuredProjects.length > 0 ? featuredProjects.slice(0, 4) : sortedProjects.slice(0, 4);

const sortedPosts = posts
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime());

const localAiSeriesPosts = sortedPosts.filter((p) => p.data.series === "local-ai");
const standalonePosts = sortedPosts.filter((p) => !p.data.series);

const allImpact = impact
	.filter((i) => i.data.visible)
	.sort((a, b) => a.data.order - b.data.order);

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
	<!-- Intro -->
	<section class="mb-14">
		<h1 class="font-[family-name:var(--font-display)] text-[2.2rem] leading-tight mb-3">Eeshan Srivastava</h1>
		<p class="text-sm text-muted-foreground mb-3.5">Data science leader, local AI builder, open-source maintainer — Seattle</p>
		<p class="text-sm text-muted-foreground max-w-[580px] leading-relaxed">
			I lead a data science team at Starbucks. 12 years across engineering, data science, and technical leadership. CS undergrad, MBA. I build web apps to test ideas about AI and experimentation, and I write about what I find. Everything is
			<a href={siteConfig.socials.github} class="text-accent hover:text-accent-2 transition-colors" target="_blank" rel="noopener noreferrer">open source</a>
			and non-commercial.
		</p>
		<div class="flex flex-wrap gap-4 mt-3.5">
			<a href={siteConfig.socials.github} class="flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground transition-colors" target="_blank" rel="noopener noreferrer">
				<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.37 1.23-3.21-.12-.3-.54-1.515.12-3.15 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.635.24 2.85.12 3.15.765.84 1.23 1.905 1.23 3.21 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
				GitHub
			</a>
			<a href={siteConfig.socials.linkedin} class="flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground transition-colors" target="_blank" rel="noopener noreferrer">
				<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
				LinkedIn
			</a>
			<a href={siteConfig.socials.substack} class="flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground transition-colors" target="_blank" rel="noopener noreferrer">
				Asymptotic ↗
			</a>
			<a href={siteConfig.socials.twitter} class="flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground transition-colors" target="_blank" rel="noopener noreferrer">
				Twitter ↗
			</a>
		</div>
	</section>

	<!-- Projects -->
	<section class="mb-14">
		<SectionTitle label="Projects" href="/projects" />
		{topProjects.map((project) => (
			<ProjectCard title={project.data.title} href={project.data.liveUrl || project.data.repoUrl} badge={project.data.featured ? { label: "Featured", variant: "featured" as const } : project.data.status === "live" ? { label: "Live", variant: "live" as const } : undefined}>
				<p class="text-sm text-muted-foreground leading-relaxed mb-2 max-w-[600px]">{project.data.hook}</p>
				<div class="flex flex-wrap items-center gap-2.5 font-[family-name:var(--font-mono)] text-[0.68rem] text-muted-foreground">
					{project.data.liveUrl && <a href={project.data.liveUrl} class="hover:text-link transition-colors" target="_blank" rel="noopener noreferrer">Live</a>}
					{project.data.liveUrl && project.data.repoUrl && <span class="text-border">·</span>}
					{project.data.repoUrl && <a href={project.data.repoUrl} class="hover:text-link transition-colors" target="_blank" rel="noopener noreferrer">Source</a>}
					{project.data.analysisUrl && <><span class="text-border">·</span><a href={project.data.analysisUrl} class="hover:text-link transition-colors" target="_blank" rel="noopener noreferrer">Analysis</a></>}
					{project.data.relatedWriting && project.data.relatedWriting.length > 0 && <><span class="text-border">·</span><a href={`/writing`} class="hover:text-link transition-colors">Writeup →</a></>}
					{(project.data.liveUrl || project.data.repoUrl) && project.data.tech.length > 0 && <span class="text-border">·</span>}
					<span>{project.data.tech.join(" · ")}</span>
				</div>
				{project.data.stats && project.data.stats.length > 0 && (
					<div class="flex gap-4 mt-2">
						{project.data.stats.map((stat) => (
							<span class="font-[family-name:var(--font-mono)] text-xs">
								<span class="font-semibold text-accent">{stat.value}</span>
								{stat.label && <span class="text-muted-foreground"> {stat.label}</span>}
							</span>
						))}
					</div>
				)}
				{(project.data.videoWebm || project.data.videoMp4) ? (
					<video autoplay muted loop playsinline preload="metadata" class="mt-3 aspect-video max-w-md rounded-lg border border-border" poster={project.data.videoPoster}>
						{project.data.videoWebm && <source src={project.data.videoWebm} type="video/webm" />}
						{project.data.videoMp4 && <source src={project.data.videoMp4} type="video/mp4" />}
					</video>
				) : (
					<VideoShimmer duration="45s" />
				)}
			</ProjectCard>
		))}
	</section>

	<!-- Writing -->
	<section class="mb-14">
		<SectionTitle label="Writing" href="/writing" />

		{localAiSeriesPosts.length > 0 && <SeriesCard seriesSlug="local-ai" />}

		{standalonePosts.slice(0, 3).map((post) => (
			<PostItem
				title={post.data.title}
				href={post.data.externalUrl}
				excerpt={post.data.description}
				date={formatDate(post.data.createdAt)}
				projectLink={post.data.relatedProject ? { label: post.data.relatedProject, href: `/projects` } : undefined}
			/>
		))}
	</section>

	<!-- Recognition -->
	<section class="mb-14">
		<SectionTitle label="Recognition" />
		<div class="flex flex-col">
			{allImpact.flatMap((cat) => cat.data.items.map((item) => (
				<RecogItem icon={cat.data.icon} text={item.text} detail={item.meta} link={item.link} year="" />
			)))}
		</div>
	</section>

	<!-- About teaser -->
	<section class="mb-14">
		<SectionTitle label="About" />
		{aboutRendered && <div class="prose prose-sm text-muted-foreground max-w-[580px] leading-relaxed"><aboutRendered.Content /></div>}
	</section>

	<!-- Subscribe -->
	<SubscribeBox />
</BaseLayout>