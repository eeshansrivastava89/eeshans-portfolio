---
import BaseLayout from "@/layouts/Base.astro";
import PostItem from "@/components/PostItem.astro";
import SubscribeBox from "@/components/SubscribeBox.astro";
import { getVisiblePosts, formatDate } from "@/data/content";

const sortedPosts = await getVisiblePosts();
---

<BaseLayout title="Writing" activePage="/writing">
	<a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1 mb-8">← Home</a>

	<h1 class="font-[family-name:var(--font-display)] text-[3rem] leading-tight mb-3">Writing</h1>
	<p class="text-base text-foreground/80 leading-relaxed mb-12">
		Essays on AI, data science, and what holds up after the hype. Published on
		<a href="https://theasymptotic.substack.com" class="text-accent hover:text-accent-2 transition-colors" target="_blank" rel="noopener noreferrer">Asymptotic</a>.
	</p>

	{sortedPosts.map((post) => (
		<PostItem
			title={post.data.title}
			href={post.data.externalUrl}
			excerpt={post.data.description}
			date={formatDate(post.data.createdAt)}
			image={post.data.coverImage}
			tags={post.data.tags}
		/>
	))}

	<SubscribeBox />
</BaseLayout>