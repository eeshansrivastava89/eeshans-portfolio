---
import BaseLayout from "@/layouts/Base.astro";
import Icon from "@/components/Icon.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import SubscribeBox from "@/components/SubscribeBox.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "@/data/config";

const aboutEntries = await getCollection("other");
const about = aboutEntries.find((e) => e.id === "about");
const aboutRendered = about ? await render(about) : null;

const experience = await getCollection("experience");
const allExperience = experience.sort((a, b) => a.data.order - b.data.order);
const work = allExperience.filter((e) => e.data.type === "work");
const education = allExperience.filter((e) => e.data.type === "education");

const impact = await getCollection("impact");
const visibleImpact = impact
	.filter((i) => i.data.visible)
	.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="About" activePage="/about">
	<a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1 mb-8">← Home</a>

	<!-- Profile photo + bio -->
	<div class="mb-10 after:clear-both after:block">
		<img
			src="/images/art-profile-eeshan.jpeg"
			alt="Eeshan Srivastava"
			class="w-[min(240px,45vw)] h-auto float-left mr-7 mb-4 rounded-2xl border border-border"
		/>
		{aboutRendered && <div class="text-base text-foreground/80 leading-relaxed [&>p]:mb-4 [&>p>a]:text-accent [&>p>a]:hover:text-accent-2 [&>p>a]:transition-colors [&>strong]:text-foreground [&>strong]:font-semibold"><aboutRendered.Content /></div>}
	</div>

	<!-- Social links -->
	<SocialLinks class="mb-4" />

	<!-- Recognition & Leadership -->
	<section class="mt-14">
		<h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-6 pb-2 border-b border-border">Recognition & Leadership</h2>
		<div class="flex flex-col">
			{visibleImpact.map((cat) => (
				<div class="py-4 border-b border-border last:border-b-0">
					<h3 class="text-[0.88rem] font-semibold text-foreground mb-2 flex items-center gap-2">
						<Icon name={cat.data.icon} size={14} className="text-accent" />
						{cat.data.title}
					</h3>
					<ul class="space-y-1.5">
						{cat.data.items.map((item: { text: string; meta?: string; link?: string }) => (
							<li class="text-[0.88rem] text-foreground/80">
								{item.link ? (
									<a href={item.link} class="text-foreground hover:text-link-2 transition-colors" target="_blank" rel="noopener noreferrer">
										{item.text}
									</a>
								) : (
									<span class="text-foreground">{item.text}</span>
								)}
								{item.meta && (
									<span class="text-xs text-muted-foreground ml-2">{item.meta}</span>
								)}
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</section>

	<!-- Experience -->
	<section class="mt-14">
		<h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-6 pb-2 border-b border-border">Experience</h2>
		<div class="flex flex-col">
			{work.map((entry) => (
				<div class="flex items-start gap-4 py-4 border-b border-border last:border-b-0">
					{entry.data.logo && (
						<img src={`/logos/${entry.data.logo}`} alt="" class="w-10 h-10 rounded-lg border border-border bg-background shrink-0" />
					)}
					<div class="min-w-0">
						<div class="font-[family-name:var(--font-mono)] text-xs text-accent tracking-wide mb-0.5">{entry.data.timespan}</div>
						<div class="font-medium text-foreground text-[0.88rem]">{entry.data.title} · {entry.data.company}</div>
						{entry.data.description && <div class="text-[0.88rem] text-foreground/75 mt-0.5">{entry.data.description}</div>}
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- Education -->
	<section class="mt-14">
		<h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-6 pb-2 border-b border-border">Education</h2>
		<div class="flex flex-col">
			{education.map((entry) => (
				<div class="flex items-start gap-4 py-4 border-b border-border last:border-b-0">
					{entry.data.logo && (
						<img src={`/logos/${entry.data.logo}`} alt="" class="w-10 h-10 rounded-lg border border-border bg-background shrink-0" />
					)}
					<div class="min-w-0">
						<div class="font-[family-name:var(--font-mono)] text-xs text-accent tracking-wide mb-0.5">{entry.data.timespan}</div>
						<div class="font-medium text-foreground text-[0.88rem]">{entry.data.title} · {entry.data.company}</div>
						{entry.data.description && <div class="text-[0.88rem] text-foreground/75 mt-0.5">{entry.data.description}</div>}
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- Substack -->
	<div class="mt-14">
		<SubscribeBox />
	</div>
</BaseLayout>