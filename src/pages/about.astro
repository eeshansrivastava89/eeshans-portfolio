---
import BaseLayout from "@/layouts/Base.astro";
import RecogItem from "@/components/RecogItem.astro";
import TimelineItem from "@/components/TimelineItem.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "@/data/config";

const aboutEntries = await getCollection("other");
const about = aboutEntries.find((e) => e.id === "about");
const aboutRendered = about ? await render(about) : null;

const experience = await getCollection("experience");
const sortedExperience = experience.sort((a, b) => a.data.order - b.data.order);

const impact = await getCollection("impact");
const allImpact = impact
	.filter((i) => i.data.visible)
	.sort((a, b) => a.data.order - b.data.order);

const socials = [
	{ label: "GitHub", handle: "@eeshansrivastava89", href: siteConfig.socials.github, icon: "github" },
	{ label: "LinkedIn", handle: "/in/eeshans", href: siteConfig.socials.linkedin, icon: "linkedin" },
	{ label: "Asymptotic", handle: "Substack newsletter", href: siteConfig.socials.substack, icon: "substack" },
	{ label: "Twitter / X", handle: "@notesundrground", href: siteConfig.socials.twitter, icon: "twitter" },
];

const interests = ["Kickboxing", "Painting", "Reading", "Basketball", "Ravenclaw"];

const recognitionByYear: { icon: string; text: string; detail?: string; link?: string; year?: string }[] = [];
for (const cat of allImpact) {
	for (const item of cat.data.items) {
		recognitionByYear.push({
			icon: cat.data.icon,
			text: item.text,
			detail: item.meta,
			link: item.link,
			year: "", // We don't have year in impact data yet
		});
	}
}
---

<BaseLayout title="About" activePage="/about">
	<a href="/" class="text-[0.82rem] text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1 mb-8">← Home</a>

	<div class="max-w-[580px]">
		<h1 class="font-[family-name:var(--font-display)] text-4xl leading-tight mb-5">
			I'm <em class="text-accent">Eeshan Srivastava</em>.
		</h1>

				{aboutRendered && <div class="text-sm text-muted-foreground leading-relaxed [&>p]:mb-3 [&>p>a]:text-accent [&>p>a]:hover:text-accent-2 [&>p>a]:transition-colors [&>strong]:text-foreground [&>strong]:font-medium"><aboutRendered.Content /></div>}
	</div>

	<!-- Recognition -->
	<section class="mt-10">
		<h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-5 pb-2 border-b border-border">Recognition</h2>
		<div class="flex flex-col">
			{allImpact.flatMap((cat) => cat.data.items.map((item) => (
				<RecogItem icon={cat.data.icon} text={item.text} detail={item.meta} link={item.link} year="" />
			)))}
		</div>
	</section>

	<!-- Background -->
	<section class="mt-10">
		<h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-5 pb-2 border-b border-border">Background</h2>
		<div class="relative pl-6 mt-4 before:absolute before:left-0 before:top-0 before:bottom-0 before:w-0.5 before:bg-border">
			{sortedExperience.map((entry) => (
				<TimelineItem
					period={entry.data.timespan}
					title={entry.data.title}
					organization={entry.data.company}
					detail={entry.data.type === "work" ? undefined : undefined}
				/>
			))}
		</div>
	</section>

	<!-- Interests -->
	<section class="mt-10">
		<h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-5 pb-2 border-b border-border">Otherwise</h2>
		<div class="flex flex-wrap gap-1.5 mt-2">
			{interests.map((interest) => (
				<span class="text-sm text-muted-foreground px-3 py-1 border border-border rounded-full">{interest}</span>
			))}
		</div>
	</section>

	<!-- Connect -->
	<section class="mt-10">
		<h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground mb-5 pb-2 border-b border-border">Connect</h2>
		<div class="flex flex-col">
			{socials.map((social) => (
				<a href={social.href} class="flex items-center gap-2.5 py-2 border-b border-border last:border-b-0 text-sm text-muted-foreground hover:text-foreground transition-colors" target="_blank" rel="noopener noreferrer">
					<span class="font-medium text-foreground">{social.label}</span>
					<span class="font-[family-name:var(--font-mono)] text-[0.75rem] text-muted-foreground">{social.handle}</span>
				</a>
			))}
		</div>
	</section>
</BaseLayout>